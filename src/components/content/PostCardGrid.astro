---
import { Calendar, Clock3, ArrowRight } from 'lucide-react';
import { withBase } from '@/lib/utils';
import type { PostEntry } from '@/lib/content';
import { estimateReadingTime } from '@/lib/readingTime';

type Props = {
  posts: PostEntry[];
  hrefPrefix: '/blog';
  ctaLabel: string;
  showReadingTime?: boolean;
  showEmptyState?: boolean;
  emptyMessage?: string;
};

const {
  posts,
  hrefPrefix,
  ctaLabel,
  showReadingTime = false,
  showEmptyState = false,
  emptyMessage = 'No posts available at the moment.',
} = Astro.props as Props;
---

{posts.length === 0 && showEmptyState ? (
  <div class="max-w-4xl mx-auto">
    <article class="rounded-2xl border bg-card p-6 text-center">
      <p class="text-muted-foreground">{emptyMessage}</p>
    </article>
  </div>
) : null}

{posts.length > 0 ? (
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
    {posts.map((post) => (
      <a
        href={withBase(`${hrefPrefix}/${post.slug}`)}
        class="group block rounded-2xl border bg-card p-6 hover:shadow-lg transition-all duration-300 hover:-translate-y-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40"
        data-tags={post.data.tags.join(',')}
      >
        <article>
          <div class="flex items-center justify-between gap-4 text-sm text-muted-foreground mb-3">
            <div class="flex items-center gap-3">
              <span class="inline-flex items-center gap-1">
                <Calendar class="h-4 w-4" />
                {post.data.pubDate.toLocaleDateString('en-US', {
                  month: 'short',
                  day: 'numeric',
                  year: 'numeric',
                })}
              </span>
              {showReadingTime ? (
                <span class="inline-flex items-center gap-1">
                  <Clock3 class="h-4 w-4" />
                  {estimateReadingTime(post.body).text}
                </span>
              ) : null}
            </div>
            <span class="inline-block px-2 py-1 rounded-full bg-primary/10 text-primary text-xs font-medium">
              {post.data.category}
            </span>
          </div>
          <h2 class="text-2xl font-bold mb-2 transition-colors group-hover:text-primary">{post.data.title}</h2>
          <p class="text-muted-foreground mb-3">{post.data.summary}</p>
          {post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mb-4">
              {post.data.tags.slice(0, 4).map((tag: string) => (
                <span class="inline-block px-2 py-0.5 rounded-md bg-muted text-muted-foreground text-xs">
                  {tag}
                </span>
              ))}
            </div>
          )}
          <span class="inline-flex items-center gap-2 text-sm font-medium text-primary group-hover:gap-3 transition-all">
            {ctaLabel}
            <ArrowRight class="h-4 w-4" />
          </span>
        </article>
      </a>
    ))}
  </div>
) : null}

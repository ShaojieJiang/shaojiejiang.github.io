---
import Layout from '../layouts/main.astro';
import { getCollection } from 'astro:content';
import { Github, Linkedin, Mail, Twitter, BookOpen, ExternalLink, GraduationCap, Briefcase, ArrowRight, Calendar } from 'lucide-react';
import { withBase } from '@/lib/utils';
import { getPostTeaserImage } from '@/lib/content';

const latestPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

const panelCardClass =
  "relative isolate rounded-2xl bg-gradient-to-b from-card via-card/95 to-card/85 dark:from-card dark:via-card dark:to-card/75 p-6 md:p-8 ring-1 ring-black/5 dark:ring-white/10 transition-all duration-300 shadow-[inset_0_1px_0_hsl(var(--background)/0.75),0_14px_32px_-24px_rgba(2,8,23,0.6)] dark:shadow-[inset_0_1px_0_rgba(255,255,255,0.08),0_18px_38px_-24px_rgba(0,0,0,0.9)]";

const publications = [
  {
    year: "2023",
    title: "Weakly Supervised Turn-level Engagingness Evaluator for Dialogues",
    authors: "Jiang, S., Vakulenko, S., & de Rijke, M.",
    venue: "Proceedings of the 2023 Conference on Human Information Interaction and Retrieval (CHIIR)",
    links: [
      { label: "PDF", href: "https://arxiv.org/abs/2302.13596" },
      { label: "Code", href: "https://github.com/ShaojieJiang/lit-seq" },
    ],
  },
  {
    year: "2022",
    title: "A Simple Contrastive Learning Objective for Alleviating Neural Text Degeneration",
    authors: "Jiang, S., Zhang, R., Vakulenko, S., & de Rijke, M.",
    venue: "arXiv preprint arXiv:2205.02517",
    links: [
      { label: "PDF", href: "https://arxiv.org/abs/2205.02517" },
      { label: "Code", href: "https://github.com/ShaojieJiang/lit-seq" },
    ],
  },
  {
    year: "2020",
    title: "TLDR: Token Loss Dynamic Reweighting for Reducing Repetitive Utterance Generation",
    authors: "Jiang, S., Wolf, T., Monz, C., & de Rijke, M.",
    venue: "arXiv preprint arXiv:2003.11963",
    links: [
      { label: "PDF", href: "https://arxiv.org/abs/2003.11963" },
      { label: "Code", href: "https://github.com/ShaojieJiang/tldr" },
    ],
  },
  {
    year: "2019",
    title: "Improving Neural Response Diversity with Frequency-Aware Cross-Entropy Loss",
    authors: "Jiang, S., Ren, P., Monz, C., & de Rijke, M.",
    venue: "The World Wide Web Conference (WWW 2019)",
    links: [
      { label: "PDF", href: "https://arxiv.org/abs/1902.09191" },
      { label: "Code", href: "https://github.com/ShaojieJiang/FACE" },
    ],
  },
  {
    year: "2018",
    title: "Why are Sequence-to-Sequence Models So Dull? Understanding the Low-Diversity Problem of Chatbots",
    authors: "Jiang, S., & de Rijke, M.",
    venue: "Proceedings of the 2018 EMNLP Workshop SCAI",
    links: [
      { label: "PDF", href: "https://arxiv.org/abs/1809.01941" },
    ],
  },
  {
    year: "2017",
    title: "Robust Struck Tracker via Color Haar-like Feature and Selective Updating",
    authors: "Jiang, S., Ning, J., Cai, C., & Li, Y.",
    venue: "Signal, Image and Video Processing",
    links: [
      { label: "PDF", href: "https://link.springer.com/article/10.1007/s11760-016-0939-3" },
    ],
  },
  {
    year: "2016",
    title: "Object Tracking via Dual Linear Structured SVM and Explicit Feature Map",
    authors: "Ning, J., Yang, J., Jiang, S., Zhang, L., & Yang, M.-H.",
    venue: "Proceedings of the IEEE Conference on Computer Vision and Pattern Recognition (CVPR 2016)",
    links: [
      { label: "PDF", href: "https://ieeexplore.ieee.org/document/7780762" },
    ],
  },
];

const experience = [
  {
    role: "Founder",
    company: "AI Colleagues",
    period: "2025 – Present",
    description: "AI agent workflow and platform development, including building Orcheo for accessible agentic workflow orchestration.",
  },
  {
    role: "Manager AI",
    company: "SKIM",
    location: "Rotterdam",
    period: "Dec 2023 – Mar 2026",
    description: "Applied cutting-edge AI to market research, including survey bots and AI-powered data analysis.",
  },
  {
    role: "Senior Machine Learning Scientist",
    company: "Huawei R&D",
    location: "Amsterdam",
    period: "Jul 2022 – Aug 2023",
    description: "Reward model and PPO development; designed the Chair toolkit for SFT, RM, and PPO training; led the ChatEval challenge at DSTC 11.",
  },
  {
    role: "Research Intern",
    company: "Replika",
    location: "Remote",
    period: "Feb 2021 – Jul 2021",
    description: "Improved chatbot engagingness through novel dialogue modeling techniques.",
  },
  {
    role: "Applied Science Intern",
    company: "Amazon",
    location: "Remote",
    period: "Jul 2020 – Sep 2020",
    description: "Review summarization with the Subjective NLP team.",
  },
];

const education = [
  {
    degree: "PhD — Open-domain Dialogue Systems",
    school: "University of Amsterdam",
    period: "Oct 2017 – Oct 2023",
    detail: "Supervisors: Maarten de Rijke, Svitlana Vakulenko",
  },
  {
    degree: "Master of Engineering",
    school: "Northwest A&F University",
    period: "Sep 2014 – Jun 2017",
    detail: "Thesis: Research on Feature Representation and Optimization Methods in Structured Object Tracking",
  },
  {
    degree: "Bachelor of Engineering",
    school: "Northwest A&F University",
    period: "Sep 2010 – Jun 2014",
    detail: "Thesis: Implementation of Single Image Haze Removal Using Dark Channel Prior",
  },
];

const skills = [
  { name: "Python", level: 90 },
  { name: "PyTorch", level: 90 },
  { name: "Git", level: 90 },
  { name: "Bash", level: 70 },
  { name: "Photography", level: 60 },
  { name: "Rust", level: 50 },
  { name: "Unity", level: 10 },
];
---

<Layout title="Shaojie Jiang — AI Researcher & Engineer">
  <!-- Hero -->
  <section class="py-20 md:py-28 border-b bg-muted/20">
    <div class="container mx-auto px-4 text-center space-y-6">
      <img
        src={withBase('/avatar.jpg')}
        alt="Shaojie Jiang"
        class="w-36 h-36 rounded-full mx-auto ring-4 ring-background shadow-xl"
        width="150"
        height="150"
      />
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight">
        Hi, I'm <span class="bg-gradient-to-r from-cyan-600 to-blue-600 dark:from-cyan-300 dark:to-blue-300 bg-clip-text text-transparent">Shaojie Jiang</span>
      </h1>
      <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto leading-relaxed">
        I build practical AI systems that bring cutting-edge technology into real-world use, with a current focus on agentic workflows through Orcheo and AI Colleagues.
      </p>
      <div class="flex justify-center gap-4 pt-2">
        <a
          href="https://github.com/ShaojieJiang"
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground hover:text-foreground transition-colors"
          aria-label="GitHub"
        >
          <Github className="h-6 w-6" />
        </a>
        <a
          href="https://linkedin.com/in/shaojie-jiang-1a69b3122"
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground hover:text-foreground transition-colors"
          aria-label="LinkedIn"
        >
          <Linkedin className="h-6 w-6" />
        </a>
        <a
          href="https://twitter.com/Shaojie_Jiang"
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground hover:text-foreground transition-colors"
          aria-label="Twitter"
        >
          <Twitter className="h-6 w-6" />
        </a>
        <a
          href="https://scholar.google.nl/citations?user=ax0e3tkAAAAJ&hl=en"
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground hover:text-foreground transition-colors"
          aria-label="Google Scholar"
        >
          <GraduationCap className="h-6 w-6" />
        </a>
        <a
          href="mailto:s.jiang@ai-colleagues.com"
          class="text-muted-foreground hover:text-foreground transition-colors"
          aria-label="Email"
        >
          <Mail className="h-6 w-6" />
        </a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="py-20 border-b bg-background">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">About</h2>
      <div class="mx-auto max-w-3xl">
        <div class={panelCardClass}>
          <div class="space-y-4 text-base md:text-lg text-muted-foreground leading-8">
            <p>
              I’m passionate about applying cutting-edge AI technologies to solve real-world problems, and making it accessible to everyone. I built <strong class="text-foreground">Orcheo</strong>, an easy-to-use agentic workflow orchestration platform.
            </p>
            <p>
              My PhD in AI and diverse industry experience have sharpened my skills in developing and deploying LLM-based solutions, from research and evaluation to production workflows and user-facing products.
            </p>
            <div class="pt-2">
              <h3 class="text-sm font-semibold text-foreground uppercase tracking-wider mb-2">Research Interests</h3>
              <div class="flex flex-wrap gap-2">
                {["AI Agents", "Workflow Orchestration", "Large Language Models", "Conversational AI", "LLM Applications", "AI Product Engineering"].map((interest) => (
                  <span class="inline-block px-3 py-1 rounded-full bg-primary/10 text-primary text-sm font-medium">
                    {interest}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Experience -->
  <section id="experience" class="py-20 border-b bg-muted/20">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">Experience</h2>
      <div class="mx-auto max-w-3xl space-y-6">
        {experience.map((job) => (
          <div class={panelCardClass}>
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-2">
              <div>
                <h3 class="text-lg font-semibold">{job.role}</h3>
                <p class="text-sm text-muted-foreground">
                  {job.company}
                  {job.location ? (
                    <>
                      {" "}
                      &middot; {job.location}
                    </>
                  ) : null}
                </p>
              </div>
              <span class="text-sm text-muted-foreground whitespace-nowrap">{job.period}</span>
            </div>
            <p class="text-sm md:text-base text-muted-foreground">{job.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Publications -->
  <section id="publications" class="py-20 border-b bg-background">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">Publications</h2>
      <div class="mx-auto max-w-3xl space-y-6">
        {publications.map((pub) => (
          <div class={panelCardClass}>
            <span class="inline-block text-xs font-medium text-muted-foreground bg-muted px-2 py-0.5 rounded mb-2">{pub.year}</span>
            <h3 class="text-base md:text-lg font-semibold mb-1">{pub.title}</h3>
            <p class="text-sm text-muted-foreground mb-1">{pub.authors}</p>
            <p class="text-sm text-muted-foreground italic mb-3">{pub.venue}</p>
            <div class="flex gap-3">
              {pub.links.map((link) => (
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1 text-sm font-medium text-primary hover:underline"
                >
                  <ExternalLink className="h-3.5 w-3.5" />
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Education -->
  <section id="education" class="py-20 border-b bg-muted/20">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">Education</h2>
      <div class="mx-auto max-w-3xl space-y-6">
        {education.map((edu) => (
          <div class={panelCardClass}>
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-1">
              <h3 class="text-lg font-semibold">{edu.degree}</h3>
              <span class="text-sm text-muted-foreground whitespace-nowrap">{edu.period}</span>
            </div>
            <p class="text-sm text-muted-foreground">{edu.school}</p>
            <p class="text-sm text-muted-foreground mt-1">{edu.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section id="skills" class="py-20 border-b bg-background">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">Skills</h2>
      <div class="mx-auto max-w-xl">
        <div class={panelCardClass}>
          <div class="space-y-4">
            {skills.map((skill) => (
              <div>
                <div class="flex justify-between mb-1">
                  <span class="text-sm font-medium">{skill.name}</span>
                  <span class="text-sm text-muted-foreground">{skill.level}%</span>
                </div>
                <div class="w-full bg-muted rounded-full h-2">
                  <div
                    class="bg-gradient-to-r from-cyan-500 to-blue-500 h-2 rounded-full transition-all duration-500"
                    style={`width: ${skill.level}%`}
                  />
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Blog -->
  <section id="blog" class="py-20 border-b bg-muted/20">
    <div class="container mx-auto px-4">
      <div class="flex items-center justify-between max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl md:text-4xl font-bold">Latest Posts</h2>
        <a
          href={withBase('/blog')}
          class="inline-flex items-center gap-1 text-sm font-medium text-primary hover:gap-2 transition-all"
        >
          View all
          <ArrowRight className="h-4 w-4" />
        </a>
      </div>
      <div class="mx-auto max-w-3xl space-y-4">
        {latestPosts.map((post) => (
          (() => {
            const teaserImage = getPostTeaserImage(post.data.image);

            return (
          <a
            href={withBase(`/blog/${post.slug}`)}
            class="group block overflow-hidden rounded-xl border bg-card transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
          >
            <div class="flex flex-col gap-4 p-5 sm:flex-row sm:items-start">
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-3 text-xs text-muted-foreground mb-2">
                  <span class="inline-flex items-center gap-1">
                    <Calendar className="h-3.5 w-3.5" />
                    {formatDate(post.data.pubDate)}
                  </span>
                  <span class="inline-block px-2 py-0.5 rounded-full bg-primary/10 text-primary font-medium">
                    {post.data.category}
                  </span>
                </div>
                <h3 class="font-semibold mb-1 transition-colors group-hover:text-primary">{post.data.title}</h3>
                <p class="text-sm text-muted-foreground">{post.data.summary}</p>
              </div>
              {teaserImage ? (
                <div class="order-first overflow-hidden rounded-lg bg-muted sm:order-none sm:w-32 sm:flex-none">
                  <div class="aspect-[4/3] sm:h-full">
                    <img
                      src={withBase(teaserImage)}
                      alt={post.data.title}
                      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                  </div>
                </div>
              ) : null}
            </div>
          </a>
            );
          })()
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="py-20 bg-muted/20">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">Contact</h2>
      <p class="text-center text-muted-foreground mb-12 max-w-lg mx-auto">
        Feel free to reach out for collaborations, research discussions, or just to say hi.
      </p>
      <div class="mx-auto max-w-md">
        <div class={panelCardClass}>
          <div class="space-y-4">
            <a href="s.jiang@ai-colleagues.com" class="flex items-center gap-3 text-sm md:text-base hover:text-primary transition-colors">
              <Mail className="h-5 w-5 text-muted-foreground" />
              s.jiang@ai-colleagues
            </a>
            <a href="https://github.com/ShaojieJiang" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-sm md:text-base hover:text-primary transition-colors">
              <Github className="h-5 w-5 text-muted-foreground" />
              ShaojieJiang
            </a>
            <a href="https://linkedin.com/in/shaojie-jiang-1a69b3122" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-sm md:text-base hover:text-primary transition-colors">
              <Linkedin className="h-5 w-5 text-muted-foreground" />
              shaojie-jiang-1a69b3122
            </a>
            <a href="https://twitter.com/Shaojie_Jiang" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-sm md:text-base hover:text-primary transition-colors">
              <Twitter className="h-5 w-5 text-muted-foreground" />
              @Shaojie_Jiang
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
